{
  "manifest_version": 3,
  "name": "Nano Banana Bridge",
  "version": "1.0.0",
  "description": "Generate images with Nano Banana Pro (GEM_PIX_2) on Google Flow via a direct API. Drive it from web pages or other extensions through chrome.runtime messaging.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "tabs",
    "scripting",
    "storage",
    "webRequest",
    "clipboardWrite"
  ],
  "host_permissions": [
    "*://labs.google/*",
    "*://aisandbox-pa.googleapis.com/*",
    "*://*.googleusercontent.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "*://labs.google/fx/*"
      ],
      "include_globs": [
        "*labs.google/fx/*/tools/flow*",
        "*labs.google/fx/tools/flow*"
      ],
      "js": [
        "content/content_main.js"
      ],
      "run_at": "document_end",
      "world": "MAIN"
    },
    {
      "matches": [
        "*://labs.google/fx/*"
      ],
      "include_globs": [
        "*labs.google/fx/*/tools/flow*",
        "*labs.google/fx/tools/flow*"
      ],
      "js": [
        "content/content_isolated.js"
      ],
      "run_at": "document_end",
      "world": "ISOLATED"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "Nano Banana Bridge"
  },
  "externally_connectable": {
    "matches": [
      "*://localhost/*",
      "*://127.0.0.1/*",
      "*://*.google.com/*"
    ],
    "accepts_tls_channel_id": false
  },
  "web_accessible_resources": [
    {
      "resources": ["flow-config.json", "api.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
